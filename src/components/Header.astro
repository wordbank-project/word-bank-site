---
import Logo from "./Logo.astro";
import { getCopy, otherLang, localeRoot, LANG_META, type Lang } from "../i18n";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const t = getCopy(lang);

// The language toggle always points at the *other* locale.
const other = otherLang(lang);
const otherRoot = localeRoot(other);
const otherMeta = LANG_META[other];

const iconClass = "w-[18px] h-[18px]";
---

<header class="nav">
    <div class="mx-auto max-w-270 px-6 nav-inner">
        <a href="#top" class="nav-logo" data-scroll-top aria-label={t.nav.backToTop}>
            <Logo withWordmark />
        </a>

        <div class="flex items-center gap-4">
            <nav class="nav-links" aria-label="Main" data-nav-links>
                {t.nav.links.map(({ href, label }) => <a href={href}>{label}</a>)}
                <a href="#top" class="button button-small" data-scroll-top>{t.nav.cta}</a>
                <!-- Language switch inside the mobile menu (hidden on desktop, where
                     the globe button in the top bar is used instead). -->
                <a
                    href={otherRoot}
                    hreflang={other}
                    data-lang-link
                    data-base={otherRoot}
                    class="hidden max-[720px]:inline-flex items-center gap-2"
                    aria-label={t.nav.langSwitch}
                >
                    <svg
                        class={iconClass}
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M2 12h20M12 2a15.3 15.3 0 0 1 0 20 15.3 15.3 0 0 1 0-20z"
                        ></path>
                    </svg>
                    {otherMeta.name}
                </a>
            </nav>

            <!-- Language switch in the top bar (desktop only; subtle). -->
            <a
                href={otherRoot}
                hreflang={other}
                data-lang-link
                data-base={otherRoot}
                class="max-[720px]:hidden inline-flex h-9 items-center gap-1.5 rounded-[10px] border border-line bg-transparent px-2.5 text-[0.8rem] font-semibold text-ink no-underline transition-colors hover:border-accent hover:text-accent"
                aria-label={t.nav.langSwitch}
            >
                <svg
                    class={iconClass}
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M2 12h20M12 2a15.3 15.3 0 0 1 0 20 15.3 15.3 0 0 1 0-20z"
                    ></path>
                </svg>
                {otherMeta.code}
            </a>

            <button
                type="button"
                class="inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-[10px] border border-line bg-transparent text-ink transition-colors hover:border-accent hover:text-accent"
                aria-label={`${t.nav.theme.prefix}: ${t.nav.theme.system}`}
                data-theme-toggle
                data-theme-prefix={t.nav.theme.prefix}
                data-theme-light={t.nav.theme.light}
                data-theme-dark={t.nav.theme.dark}
                data-theme-system={t.nav.theme.system}
            >
                <svg
                    class={`${iconClass} hidden`}
                    data-icon="light"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <circle cx="12" cy="12" r="4"></circle>
                    <path
                        d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
                    ></path>
                </svg>
                <svg
                    class={`${iconClass} hidden`}
                    data-icon="dark"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"
                    ></path>
                </svg>
                <svg
                    class={iconClass}
                    data-icon="system"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <rect x="3" y="4" width="18" height="13" rx="2"></rect>
                    <path d="M8 21h8M12 17v4"></path>
                </svg>
            </button>

            <button
                type="button"
                class="nav-toggle"
                aria-expanded="false"
                aria-label={t.nav.openMenu}
                data-nav-toggle
                data-open-label={t.nav.openMenu}
                data-close-label={t.nav.closeMenu}>☰</button
            >
        </div>
    </div>
</header>

<script>
    // --- Mobile menu ---------------------------------------------------------
    const navToggle =
        document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
    const links = document.querySelector<HTMLElement>("[data-nav-links]");

    const openLabel = navToggle?.dataset.openLabel ?? "Open menu";
    const closeLabel = navToggle?.dataset.closeLabel ?? "Close menu";

    const closeMenu = () => {
        if (!navToggle || !links) return;
        links.classList.remove("open");
        navToggle.setAttribute("aria-expanded", "false");
        navToggle.setAttribute("aria-label", openLabel);
        navToggle.textContent = "☰";
    };

    if (navToggle && links) {
        navToggle.addEventListener("click", () => {
            const open = links.classList.toggle("open");
            navToggle.setAttribute("aria-expanded", String(open));
            navToggle.setAttribute("aria-label", open ? closeLabel : openLabel);
            navToggle.textContent = open ? "✕" : "☰";
        });
        links
            .querySelectorAll("a")
            .forEach((a) => a.addEventListener("click", closeMenu));
    }

    // --- Language toggle: keep the current #section when switching locale,
    //     and remember the choice so return visits land in the same language
    //     (the pre-paint script in Layout.astro reads localStorage "lang"). ----
    const langLinks = Array.from(
        document.querySelectorAll<HTMLAnchorElement>("[data-lang-link]"),
    );
    const langFor = (base: string): "en" | "nl" => (base === "/nl/" ? "nl" : "en");
    const syncLangHref = () =>
        langLinks.forEach((l) => {
            l.href = (l.dataset.base ?? "/") + location.hash;
        });
    if (langLinks.length) {
        syncLangHref();
        window.addEventListener("hashchange", syncLangHref);
        langLinks.forEach((l) =>
            l.addEventListener("click", () => {
                try {
                    localStorage.setItem("lang", langFor(l.dataset.base ?? "/"));
                } catch {
                    /* ignore */
                }
            }),
        );
    }

    // --- Theme toggle: light → dark → system, persisted in localStorage ------
    type Pref = "light" | "dark" | "system";
    const ORDER: Pref[] = ["light", "dark", "system"];
    const themeBtn = document.querySelector<HTMLButtonElement>(
        "[data-theme-toggle]",
    );
    const mql = window.matchMedia("(prefers-color-scheme: dark)");

    const getPref = (): Pref => {
        const v = localStorage.getItem("theme");
        return v === "light" || v === "dark" || v === "system" ? v : "system";
    };
    const resolve = (pref: Pref): "dark" | "light" =>
        pref === "dark" || (pref === "system" && mql.matches)
            ? "dark"
            : "light";

    const apply = (pref: Pref) => {
        document.documentElement.dataset.theme = resolve(pref);
        if (!themeBtn) return;
        themeBtn
            .querySelectorAll<SVGElement>("[data-icon]")
            .forEach((el) =>
                el.classList.toggle("hidden", el.dataset.icon !== pref),
            );
        const prefix = themeBtn.dataset.themePrefix ?? "Theme";
        const names: Record<Pref, string> = {
            light: themeBtn.dataset.themeLight ?? "light",
            dark: themeBtn.dataset.themeDark ?? "dark",
            system: themeBtn.dataset.themeSystem ?? "system",
        };
        themeBtn.setAttribute("aria-label", `${prefix}: ${names[pref]}`);
    };

    if (themeBtn) {
        apply(getPref());
        themeBtn.addEventListener("click", () => {
            const next = ORDER[(ORDER.indexOf(getPref()) + 1) % ORDER.length];
            try {
                localStorage.setItem("theme", next);
            } catch {
                /* ignore */
            }
            apply(next);
        });
        mql.addEventListener("change", () => {
            if (getPref() === "system") apply("system");
        });
    }

    // --- Scroll to top: the logo and the "Get the app" button. Works on mobile
    //     too, and closes the open nav menu first. Falls back to the #top anchor
    //     when JS is off. Honors reduced-motion.
    const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
    ).matches;
    document
        .querySelectorAll<HTMLAnchorElement>("[data-scroll-top]")
        .forEach((el) =>
            el.addEventListener("click", (e) => {
                e.preventDefault();
                closeMenu();
                window.scrollTo({ top: 0, behavior: reduceMotion ? "auto" : "smooth" });
                // Drop the section hash so the URL reflects the top of the page
                // (just / or /nl/) — otherwise switching language would jump back
                // to the last-visited section.
                if (location.hash) {
                    history.replaceState(null, "", location.pathname + location.search);
                    syncLangHref();
                }
            }),
        );
</script>
