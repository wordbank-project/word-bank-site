---
// Brand mark — kept in sync with the app's logo (word-bank/assets/logo.svg):
// a rounded accent square holding a white open book + bookmark. Ported as inline
// SVG (not an <img>) so the accent square follows --accent and the wordmark
// themes, and the same mark can be reused at any size.
//
// `withWordmark` adds the two-tone "Word Bank" wordmark beside the mark —
// "Word" in ink, "Bank" in accent, matching logo.svg's .word/.bank fills.
interface Props {
    size?: number;
    withWordmark?: boolean;
}

const { size = 30, withWordmark = false } = Astro.props;
---

<span class="logo">
    <svg
        class="logo-mark"
        width={size}
        height={size}
        viewBox="0 0 220 220"
        role="img"
        aria-label={withWordmark ? "Word Bank logo" : "Word Bank"}
    >
        <rect x="0" y="0" width="220" height="220" rx="42" fill="var(--accent)"></rect>
        <rect x="36" y="28" width="132" height="164" rx="22" fill="none" stroke="#fff" stroke-width="10"></rect>
        <rect x="166" y="72" width="18" height="54" rx="5" fill="#fff"></rect>
        <rect x="166" y="136" width="18" height="36" rx="5" fill="#fff"></rect>
        <path d="M72 82 C86 72 108 72 122 84 L122 152 C108 142 86 142 72 150Z" fill="#fff"></path>
        <path d="M122 84 C136 72 158 72 172 82 L172 150 C158 142 136 142 122 152Z" fill="#EAF5FF"></path>
        <path d="M122 84V152" stroke="var(--accent)" stroke-width="2.5"></path>
        <path
            d="M72 150C86 140 108 140 122 152 M122 152C136 140 158 140 172 150"
            fill="none"
            stroke="var(--accent)"
            stroke-width="2.5"></path>
    </svg>
    {
        withWordmark && (
            <span class="logo-wordmark">
                <span class="text-ink">Word</span><span class="text-accent">Bank</span>
            </span>
        )
    }
</span>

<style>
    .logo {
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .logo-mark {
        display: block;
        border-radius: 8px;
        flex-shrink: 0;
    }

    .logo-wordmark {
        font-weight: 700;
        font-size: 1.1rem;
        letter-spacing: -0.01em;
    }

    /* Tiny gap between the two halves so "WordBank" reads as one wordmark. */
    .logo-wordmark > span + span {
        margin-left: 0.18em;
    }
</style>
