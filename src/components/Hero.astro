---
import FloatingWords from "./FloatingWords.astro";
import PhoneMockup from "./PhoneMockup.astro";
import WordWall from "./WordWall.astro";
---

<section id="top" class="hero">
    <FloatingWords />
    <div
        class="relative z-1 mx-auto grid max-w-270 grid-cols-[1.15fr_0.85fr] items-center gap-12 px-6 max-[720px]:grid-cols-1"
    >
        <div>
            <h1 class="text-[clamp(2rem,5vw,3.1rem)]">
                Turn the books you read into <span class="text-accent"
                    ><a class="hover:saturate-200" href="#dictionary"
                        >vocabulary</a
                    > you keep</span
                >
            </h1>
            <p class="max-w-130 text-[1.1rem] text-ink-soft">
                <span class="italic">Word Bank</span> is a reading companion. Track
                what you want to read, are reading, or have read — and every time
                a word stops you, save it with its definition, your sentence, and
                your personal notes.
            </p>
            <p class="mt-4 text-[0.9rem] text-ink-muted">
                Free during beta · No account · Works offline
            </p>
            <div id="download" class="my-7 flex flex-wrap gap-3.5">
                <a class="button" href="#">
                    Download for Android <small>(beta)</small>
                </a>
                <span class="button button-ghost" aria-disabled="true"
                    >iOS — coming soon</span
                >
                <span class="button button-ghost" aria-disabled="true"
                    >Web — coming soon</span
                >
            </div>
            <div class="mt-5">
                <WordWall />
            </div>
        </div>
        <PhoneMockup />
    </div>
</section>
