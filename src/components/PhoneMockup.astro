---
import { MOCK_BOOKS } from "../content";
import type { ReadStatus } from "../content";
import { getCopy, type Lang } from "../i18n";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const t = getCopy(lang);

const FILTERS: { value: ReadStatus | "all"; label: string }[] = [
    { value: "all", label: t.phone.filters.all },
    { value: "want", label: t.phone.filters.want },
    { value: "reading", label: t.phone.filters.reading },
    { value: "read", label: t.phone.filters.read },
];
---

<!-- TODO: make it interactive -->
<div class="phone" role="img" aria-label={t.phone.aria}>
    <div class="phone-screen">
        <div class="phone-header">{t.phone.readList}</div>

        <div class="phone-filters">
            {
                FILTERS.map(({ value, label }) => (
                    <span
                        class:list={[
                            "phone-pill",
                            { selected: value === "all" },
                        ]}
                    >
                        {label}
                    </span>
                ))
            }
        </div>

        <div class="phone-list">
            {
                MOCK_BOOKS.map((book) => (
                    <div class="phone-row">
                        <span
                            class="phone-cover"
                            style={`background-color:${book.coverColor}`}
                        />
                        <span class="phone-row-info">
                            <span class="phone-row-title">{book.title}</span>
                            <span class="phone-row-author">{book.author}</span>
                            <span
                                class={`phone-status phone-status-${book.status}`}
                            >
                                {t.statusLabels[book.status]}
                            </span>
                        </span>
                        <span class="phone-badge">
                            <span class="phone-badge-count">
                                {book.wordCount}
                            </span>
                            <span class="phone-badge-label">
                                {book.wordCount === 1
                                    ? t.phone.wordSingular
                                    : t.phone.wordPlural}
                            </span>
                        </span>
                    </div>
                ))
            }
        </div>

        <div class="phone-tabbar">
            <span>{t.phone.tabs.search}</span>
            <span class="active">{t.phone.tabs.readList}</span>
            <span>{t.phone.tabs.wordList}</span>
        </div>
    </div>
</div>
