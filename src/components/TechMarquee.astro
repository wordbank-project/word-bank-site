---
import { REPO_URL, TECH } from "../content";
import { getCopy, type Lang } from "../i18n";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const t = getCopy(lang);

// Rendered twice so the track can translate -50% and loop seamlessly; the
// second copy is decorative (hidden from assistive tech, out of the tab order).
---

<section class="section reveal" aria-label={t.tech.heading}>
    <div class="mx-auto mb-9 max-w-270 px-6 text-center">
        <h2>{t.tech.heading}</h2>
        <a class="max-w-135 text-ink-soft">
            <a href={REPO_URL} target="_blank" rel="noopener noreferrer">
                {t.tech.blurbLink}</a
            ><br />
            {t.tech.blurbRest}
        </a>
    </div>

    <div class="marquee">
        <div class="marquee-track">
            {
                TECH.map((tech) => (
                    <a
                        class:list={[
                            "tech-chip",
                            { "tech-chip-accent": tech.highlight },
                        ]}
                        href={tech.url}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        {tech.name}
                    </a>
                ))
            }
            {
                TECH.map((tech) => (
                    <a
                        class:list={[
                            "tech-chip",
                            { "tech-chip-accent": tech.highlight },
                        ]}
                        href={tech.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-hidden="true"
                        tabindex="-1"
                    >
                        {tech.name}
                    </a>
                ))
            }
        </div>
    </div>
</section>
