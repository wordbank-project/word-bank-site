---
import Logo from "./Logo.astro";
import { getCopy, type Lang } from "../i18n";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const t = getCopy(lang);
const year = new Date().getFullYear();
---

<footer class="border-t border-line py-7">
    <div
        class="mx-auto flex max-w-270 flex-wrap items-center justify-between gap-3 px-6 text-ink-soft"
    >
        <span class="inline-flex items-center gap-2">
            <Logo size={24} /> Word Bank © {year}
        </span>
        <span class="text-[0.9rem] text-ink-muted">{t.footer.tagline}</span>
    </div>
</footer>
