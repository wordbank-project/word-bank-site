---
import { GLOSSARY_FALLBACK } from "../content";

// Map a part of speech to the colour-coded utility (mirrors the app's POS_COLORS;
// the same logic is duplicated in the client script for live feed rows).
function posClass(pos: string): string {
    const p = pos.toLowerCase();
    if (p.startsWith("noun")) return "text-pos-noun";
    if (p.startsWith("verb")) return "text-pos-verb";
    if (p.startsWith("adject") || p === "adj") return "text-pos-adjective";
    if (p.startsWith("adverb") || p === "adv") return "text-pos-adverb";
    return "text-accent";
}
---

{
    /* Trigger — drop into the hero. Opens the glossary of words people are saving. */
}
<button
    id="wordwall-open"
    type="button"
    class="inline-flex cursor-pointer items-center gap-1.5 rounded-[10px] border border-line px-4 py-2.5 text-[0.95rem] font-semibold text-ink transition-colors hover:border-accent hover:text-accent"
    aria-haspopup="dialog"
>
    ✦ See the words users have currently saved
</button>

{/* Glossary modal — app-style bottom sheet, hidden until opened. */}
<div
    id="wordwall-modal"
    class="fixed inset-0 z-50 hidden items-end justify-center"
    aria-hidden="true"
>
    <div
        data-ww-backdrop
        class="absolute inset-0 bg-black/40 opacity-0 transition-opacity duration-200"
    >
    </div>
    <div
        data-ww-panel
        role="dialog"
        aria-modal="true"
        aria-label="Words users are saving"
        class="relative flex max-h-[80%] w-full max-w-[520px] translate-y-full flex-col overflow-hidden rounded-t-[16px] border border-line bg-surface shadow-(--shadow) transition-transform duration-250"
    >
        <div
            class="flex items-center justify-between gap-3 border-b border-line px-4 py-3.5"
        >
            <span class="truncate text-[1rem] font-bold text-ink"
                >Words users have currently saved:</span
            >
            <button
                data-ww-close
                type="button"
                class="cursor-pointer text-[1.1rem] leading-none text-ink-muted hover:text-ink"
                aria-label="Close">✕</button
            >
        </div>

        <div data-ww-list class="overflow-y-auto">
            {
                GLOSSARY_FALLBACK.map((w) => (
                    <div data-ww-row class="border-t border-line px-4 py-3.5">
                        <div class="flex flex-wrap items-baseline gap-2">
                            <span class="text-[1rem] font-bold text-ink">
                                {w.word}
                            </span>
                            {w.phonetic && (
                                <span class="font-mono text-[0.8rem] text-ink-muted">
                                    {w.phonetic}
                                </span>
                            )}
                            <span
                                class:list={[
                                    "text-[0.8rem] italic",
                                    posClass(w.partOfSpeech),
                                ]}
                            >
                                {w.partOfSpeech}
                            </span>
                        </div>
                        <p class="mt-0.5 text-[0.9rem] text-ink-soft">
                            {w.definition}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</div>

<script>
    import { backDismiss } from "../lib/back-dismiss";

    type FeedWord = {
        word: string;
        count?: number;
        definition?: string | null;
        partOfSpeech?: string | null;
        phonetic?: string | null;
    };

    const modal = document.getElementById("wordwall-modal");
    const openBtn = document.getElementById("wordwall-open");

    if (modal && openBtn) {
        const panel = modal.querySelector<HTMLElement>("[data-ww-panel]")!;
        const backdrop =
            modal.querySelector<HTMLElement>("[data-ww-backdrop]")!;
        const list = modal.querySelector<HTMLElement>("[data-ww-list]")!;
        const reduceMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
        ).matches;
        const base = import.meta.env.PUBLIC_WORDS_API_URL as string | undefined;

        const posClass = (pos: string): string => {
            const p = pos.toLowerCase();
            if (p.startsWith("noun")) return "text-pos-noun";
            if (p.startsWith("verb")) return "text-pos-verb";
            if (p.startsWith("adject") || p === "adj")
                return "text-pos-adjective";
            if (p.startsWith("adverb") || p === "adv") return "text-pos-adverb";
            return "text-accent";
        };

        // Replace the build-time fallback rows with live saved words (with definitions).
        const renderRows = (words: FeedWord[]) => {
            const withDefs = words.filter((w) => w.word && w.definition);
            if (withDefs.length === 0) return; // keep the fallback
            list.querySelectorAll("[data-ww-row]").forEach((el) => el.remove());
            for (const w of withDefs) {
                const row = document.createElement("div");
                row.setAttribute("data-ww-row", "");
                row.className = "border-t border-line px-4 py-3.5";
                const head = document.createElement("div");
                head.className = "flex flex-wrap items-baseline gap-2";
                const word = document.createElement("span");
                word.className = "text-[1rem] font-bold text-ink";
                word.textContent = w.word;
                head.appendChild(word);
                if (w.phonetic) {
                    const ph = document.createElement("span");
                    ph.className = "font-mono text-[0.8rem] text-ink-muted";
                    ph.textContent = w.phonetic;
                    head.appendChild(ph);
                }
                if (w.partOfSpeech) {
                    const pos = document.createElement("span");
                    pos.className = `text-[0.8rem] italic ${posClass(w.partOfSpeech)}`;
                    pos.textContent = w.partOfSpeech;
                    head.appendChild(pos);
                }
                const def = document.createElement("p");
                def.className = "mt-0.5 text-[0.9rem] text-ink-soft";
                def.textContent = w.definition ?? "";
                row.appendChild(head);
                row.appendChild(def);
                list.appendChild(row);
            }
        };

        const close = () => {
            backdrop.classList.add("opacity-0");
            panel.classList.add("translate-y-full");
            modal.setAttribute("aria-hidden", "true");
            const hide = () => {
                modal.classList.add("hidden");
                modal.classList.remove("flex");
            };
            if (reduceMotion) hide();
            else setTimeout(hide, 250);
        };

        // Let the phone/browser Back button close the modal instead of leaving the site.
        const { pushOnOpen, requestClose } = backDismiss({
            key: "wwOpen",
            isOpen: () => !modal.classList.contains("hidden"),
            close,
        });

        const open = () => {
            modal.classList.remove("hidden");
            modal.classList.add("flex");
            modal.setAttribute("aria-hidden", "false");
            requestAnimationFrame(() => {
                backdrop.classList.remove("opacity-0");
                panel.classList.remove("translate-y-full");
            });
            panel.focus?.();
            pushOnOpen();
        };

        openBtn.addEventListener("click", open);
        modal
            .querySelector("[data-ww-close]")
            ?.addEventListener("click", requestClose);
        backdrop.addEventListener("click", requestClose);
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && !modal.classList.contains("hidden"))
                requestClose();
        });

        // Pull live saved words once (they replace the curated fallback).
        if (base) {
            fetch(`${base}/words?order=top&limit=120`)
                .then((r) => (r.ok ? r.json() : null))
                .then((data) => {
                    if (Array.isArray(data)) renderRows(data as FeedWord[]);
                })
                .catch(() => {
                    /* keep the fallback */
                });
        }
    }
</script>
